# Copy this file to .env in the same folder and fill in your key.
# Smart Match loads .env automatically when you run: npm start

ANTHROPIC_API_KEY=
# Must match a model your key can access (Console → API). Old IDs like claude-3-5-sonnet-20241022 may 404.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: server port (default 3000)
# PORT=3000
